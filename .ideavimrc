set scrolloff=5
set linenumber
set showmode
set showcmd
set visualbell
"Note: this is bugged, overwriting visual blocks with p no longer works
"set clipboard+=unnamed

set ignorecase
set smartcase
set incsearch
set hlsearch

let mapleader = " "

set surround
set highlightedyank
set which-key
set commentary

" For which-key
set notimeout
set timeoutlen=5000

" Idea settings
set ideajoin
set idearefactormode=keep

" Tab navigation
nnoremap <A-n> :tabnext<CR>
nnoremap <A-p> :tabprev<CR>

" Easy visual indentation
vnoremap < <gv
vnoremap > >gv

" File navigation
map <leader>sf <action>(GotoFile)
map <leader>s. <action>(RecentFiles)
map <leader>sg <action>(FindInPath)
"Note: this is bugged, Switcher just becomes RecentFiles
map <leader><leader> <Action>(Switcher)
map <leader>sl <action>(RecentLocations)

" Esc runs :noh
nnoremap <esc> :noh<CR><esc>
nnoremap <C-c> :noh<CR><esc>
nnoremap <C-[> :noh<CR><esc>

" Hide windows
map <A-m> <action>(HideAllWindows)

" Idea keymaps
map <leader>e <Action>(Run)
map <leader>d <Action>(Debug)
map <leader>r <Action>(RenameElement)
map <leader>c <Action>(Stop)
map <leader>z <Action>(ToggleDistractionFreeMode)
map <leader>s <Action>(SelectInProjectView)
map <leader>a <Action>(Annotate)
map <leader>h <Action>(Vcs.ShowTabbedFileHistory)
map <S-Space> <Action>(GotoNextError)
